{
  "description": "vibe-closer plugin hooks — auto-update reminders",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/check-plugin-update.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
